_default:
    just --list

target_dir := "--target-dir=../../target/wheels"

build MODE='':
    maturin build {{target_dir}} {{MODE}}

develop:
    maturin develop {{target_dir}}

test:
    maturin develop {{target_dir}} --quiet

    # lutra codegen
    cargo run -p lutra-cli --quiet -- \
      codegen --project=tests/lutra.lt tests/lutra_generated.py --programs-sql-pg ''

    # check
    ty check python/lutra_runner_postgres tests
    ruff check python/lutra_runner_postgres tests

    # tests
    usql postgres://postgres:pass@localhost:5416 -f tests/init.sql
    python -m unittest tests/main.py
