# === std_fold_00
func main() -> fold(
  [1, 2, 3, 4, 5]: [Int64],
  0,
  func (s: Int64, n: Int64): Int64 -> n + s
)
# >
15

# === std_fold_01
func main() -> fold(
  [1, 2, 3, 4, 5]: [Int64],
  {0, 0}: {sum: Int64, count: Int64},
  func (s, n: Int64) -> {sum = s.sum + n, count = s.count + 1}
)
# >
{
  sum = 15,
  count = 5,
}

# === std_scan_00
