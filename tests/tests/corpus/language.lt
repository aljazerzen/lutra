  4.20,
  4.02,
  3112212123123123.11,
  -3112212123123123.11,
]

# === std_option_or_else_00
func main() -> .some("hello") | option::or_else("world")
# >
"hello"

# === std_option_or_else_01
func main() -> .none | option::or_else("fallback")
# >
"fallback"

# === std_option_or_else_02
func main() -> .none: enum {none, some: Text} | option::or_default()
# >
""

# === std_option_map_00
func main() -> .some("world") | option::map(x -> f"Hello {x}!")
# >
some("Hello world!")

# === std_option_flat_map_00
func main() -> (
  .some("world")
  | option::flat_map(x -> .none: enum {none, some: Int32})
)
# >
none

# === std_option_zip_00
func main() -> [
  {.some("hello"), .some("world")},
  {.none, .some("world")},
  {.some("hello"), .none},
  {.none, .none},
] | map(x -> option::zip(x.0, x.1))
# >
[
  some({
    "hello",
    "world",
  }),
  none,
  none,
  none,
]

# === custom_type_00
type MyInt: Int32
func main() -> to_int64(4: MyInt)
