      @1970-01-01T00:00:00.010000,
    ],
  },
]

# === std_group_06
func main() -> (
  [Timestamp(0), Timestamp(10000)]
  | map(x -> [x, x])
  | group(xs -> xs | index(0) | or_default)
  | sort(x -> x.key.0)
)
# >
[
  {
    key = @1970-01-01T00:00:00.000000,
    values = [
      [
        @1970-01-01T00:00:00.000000,
        @1970-01-01T00:00:00.000000,
      ],
    ],
  },
  {
    key = @1970-01-01T00:00:00.010000,
    values = [
      [
        @1970-01-01T00:00:00.010000,
        @1970-01-01T00:00:00.010000,
      ],
    ],
  },
]

