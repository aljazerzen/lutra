# --- [ Language tests ] ---
#
# This file contains tests for the language itself.
# It is read by the main.rs and exposed as a series of cargo-compatible tests.
# A test consists of:
#
#    #  === <test name>       (test name)
#    # skip: Interpreter       (optional)
#    # skip: postgres          (optional)
#    # skip: duckdb            (optional)
#    <lutra project code>
#    # <                   (input marker)
#    <input>                   (optional)
#    # >                  (output marker)
#    <output>

# === constant_00
const main = {1: Int32, [false, true], "hello"}
# >
{
  1,
  [
    false,
    true,
  ],
  "hello",
}

# === bindings_00
const a: Int32 = 4
func main() -> [{a, a + 1}, {a + 2, a + 3}]
# >
[
  {
    a = 4,
    5,
  },
  {
    a = 6,
    7,
  },
]

# === bindings_01
const a = {3: Int32, false}
func main() -> [{a.0, a.1}, {a.0 + 1, !a.1}]
# >
[
  {
    3,
    false,
  },
  {
    4,
    true,
  },
]

# === bindings_02
const a: [Int16] = [1, 2]
func main() -> [
  {
    a | index(0) | option::or_default,
    a | index(1) | option::or_default,
  },
  {
    a | index(0) | option::or_default | add(1),
    a | index(1) | option::or_default | add(1),
  }
]
# >
[
  {
    1,
    2,
  },
  {
    2,
    3,
  },
]

# === bindings_03
const a: [Int16] = [1, 2, 3]
func main() -> {true, map(a, func (x: Int16) -> x * 2), false}
# >
{
  true,
  [
    2,
    4,
    6,
  ],
  false,
}

# === bindings_04
const a: [Int32] = [1, 2, 3]
func main() -> {
  true,
  a | map(func (x: Int32) -> x * 2) | index(1),
  false
}
# >
{
  true,
  some(4),
  false,
}

# === complex_00

const x: [Int16] = [
  1, 4, 2, 3, 2, 3, 4, 5, 1, 2
]

func main() -> {
  a = 1: Int32 + 2,
  {3: Int64, 3 + 1: Int16},
  {2: Int32, 2 + 1: Int16},
  hello = (
    x
    | map(func (y: Int16) -> y + 1)
    | filter(func (y: Int16) -> !(y > 3))
    | sort(func (x: Int16) -> x)
    | map(func (y: Int16) -> y % 3)
  )
}

# >
{
  a = 3,
  {
    3,
    4,
  },
  {
    2,
    3,
  },
  hello = [
    2,
    2,
    0,
    0,
    0,
  ],
}

