  [
    3,
    1,
    2,
  ],
}

# === std_to_columnar_01
func main() -> to_columnar([{false,"three"},{true,"one"},{false, "two"}])
# >
{
  [
    false,
    true,
    false,
  ],
  [
    "three",
    "one",
    "two",
  ],
}

# === std_to_columnar_02
func main() -> to_columnar([
  {false, "three", true},
  {true,  "one",   false},
  {false, "two",   false},
])
# >
{
  [
    false,
    true,
    false,
  ],
  [
    "three",
    "one",
    "two",
  ],
  [
    true,
    false,
    false,
  ],
}

