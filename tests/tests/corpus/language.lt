# === std_aggregate_00
const my_rel: [{Int64, Int64}] = [{5,3},{65,1},{3, 2}]
func main() -> aggregate(my_rel, func (x: {[Int64], [Int64]}) -> {min(x.0), min(x.1)})
# >
{
  some(3),
  some(1),
}

# === std_aggregate_01
func main() -> (
  [{false, "hello"}, {false, "world"}, {true, "!"}]
  | aggregate(func (x: {[Bool], [Text]}) ->
    {index(x.0, 0), index(x.1, 2)}
  )
)
# >
{
  some(false),
  some("!"),
}

