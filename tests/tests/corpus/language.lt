# === std_scan_01
func main() -> scan(
  [1, 2, 3, 4, 5]: [Int64],
  {0, 0}: {sum: Int64, count: Int64},
  func (s, n: Int64) -> {sum = s.sum + n, count = s.count + 1}
)
# >
[
  {
    sum = 1,
    count = 1,
  },
  {
    sum = 3,
    count = 2,
  },
  {
    sum = 6,
    count = 3,
  },
  {
    sum = 10,
    count = 4,
  },
  {
    sum = 15,
    count = 5,
  },
]

# === std_loop_until_empty_00
func main() -> (
  [0: Int16]
  | loop_until_empty(v ->
    v
    | map(i -> i + 1)
    | filter(i -> i < 10)
  )
)
# >
