# === var_binding_00
func main() -> (
  let a = false;
  {a, a, !a}
)
# >
{
  a = false,
  a = false,
  true,
}

# === var_binding_01
func main() -> (
  [1, 2, 3]: [Int32]
  | map(x -> (
    let a = x * 2;
    a * a
  ))
)
# >
[
  4,
  16,
  36,
]

# === var_binding_02
func main() -> (
  [1, 2, 3]: [Int32]
  | map(x -> (
    let a = x * 2;
    let b = a * 2;
    let c = -b;
    c
  ))
)
# >
[
  -4,
  -8,
  -12,
]

# === labelled_args_00
func main() -> {
  # Without using labels
  calculate(1, 2, 3),

  # Using the labels
  calculate(1, add = 2, multiply = 3),

  # Using the labels in a different order
  calculate(1, multiply = 3, add = 2),
}

func calculate(value: Int32, add addend: Int32, multiply multiplier: Int32) -> (
  value * multiplier + addend
)
# >
{
  5,
  5,
  5,
}

