# === std_group_01
func main() -> (
  [
    {1, false, 10},
    {2, false, 21},
    {2, false, 22},
    {1, true, 10}
  ]: [{Int64, Bool, Int64}]
  | group(func (x: {Int64, Bool, Int64}) -> {x.0, x.2})
  | sort(x -> x.key.0 + x.key.1)
)

# >
[
  {
    key = {
      1,
      10,
    },
    values = [
      {
        1,
        false,
        10,
      },
      {
        1,
        true,
        10,
      },
    ],
  },
  {
    key = {
      2,
      21,
    },
    values = [
      {
        2,
        false,
        21,
      },
    ],
  },
  {
    key = {
      2,
      22,
    },
    values = [
      {
        2,
        false,
        22,
      },
    ],
  },
]

# === std_group_02
func main() -> (
  [
    {1, false, 10},
    {2, false, 21},
    {2, false, 22},
    {1, true, 10}
  ]: [{Int64, Bool, Int64}]
  | group(
    func (x: {Int64, Bool, Int64}) -> {x.0, x.2}
  )
  | sort(x -> x.key.0 + x.key.1)
  | map(partition -> {
    k = partition.key.0,
    v = sum(map(
      partition.values,
      func (x: {Int64, Bool, Int64}) -> x.2
    )),
  })
)
# >
[
  {
    k = 1,
    v = 20,
  },
  {
    k = 2,
    v = 21,
  },
  {
    k = 2,
    v = 22,
  },
]

# === std_group_03
func main() -> (
  [Timestamp(0), Timestamp(10), Timestamp(1779117303000000)]
  | group(e -> (
      e | timestamp::to_date("UTC") | date::to_year_month_day | ymd -> ymd.0
    ))
  | sort(e -> e.key)
)
# >
[
  {
    key = 1970,
    values = [
      @1970-01-01T00:00:00.000000,
      @1970-01-01T00:00:00.000010,
    ],
  },
  {
    key = 2026,
    values = [
      @2026-05-18T15:15:03.000000,
    ],
  },
]

