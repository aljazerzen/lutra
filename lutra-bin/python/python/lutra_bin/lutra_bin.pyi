from .common import Codec

class BytesMut:
    def __init__(self) -> None: ...
    def into_bytes(self) -> bytes: ...

class UnitCodec:
    def head_bytes(self) -> int: ...
    def decode(self, buf: bytes) -> tuple[()]: ...
    def encode_head(self, value: tuple[()], buf: BytesMut) -> tuple[()]: ...
    def encode_body(
        self, value: tuple[()], head_residual: tuple[()], buf: BytesMut
    ) -> None: ...

