class ArrayCodec[I: Codec]:
    def __init__(self, item_codec: I) -> None: ...
    def head_bytes(self) -> int: ...
    def decode(self, buf: bytes) -> list: ...
    def encode_head(self, value: list, buf: BytesMut) -> int: ...
    def encode_body(self, value: list, head_residual: int, buf: BytesMut) -> None: ...

class EnumCodecHelper:
    def __init__(self, format: bytes) -> None: ...
    def decode_head(self, buf: bytes) -> tuple[int, int]: ...
    def encode_head_tag(self, tag: int, buf: BytesMut) -> int | None: ...
    def encode_head_padding(self, tag: int, buf: BytesMut) -> None: ...
    def encode_body_ptr(self, residual: int, buf: BytesMut) -> None: ...

class Ty:
    @staticmethod
    def decode(buf: bytes) -> Ty: ...
    def encode(self) -> bytes: ...
